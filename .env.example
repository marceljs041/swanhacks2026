# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Cloud AI fallback (used by apps/api when no local sidecar)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Local AI sidecar (Electron desktop)
# Electron uses apps/api/.venv/bin/python3 automatically if present (has FastAPI).
# Override if needed:
# STUDYNEST_PYTHON=/Users/you/code/swanhacks2026/apps/api/.venv/bin/python3
STUDYNEST_LOCAL_AI_URL=http://127.0.0.1:8765
STUDYNEST_GEMMA_MODEL_PATH=./app-data/models/gemma-3-4b-it-q4_k_m.gguf
STUDYNEST_GEMMA_CTX_SIZE=8192
STUDYNEST_GEMMA_THREADS=4

# StudyNest cloud API
STUDYNEST_API_URL=http://127.0.0.1:8000
