# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Cloud AI fallback (used by apps/api when no local sidecar)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Local AI sidecar (Electron desktop)
# Electron uses apps/api/.venv/bin/python3 automatically if present (has FastAPI).
# Override if needed:
# STUDYNEST_PYTHON=/Users/you/code/swanhacks2026/apps/api/.venv/bin/python3
STUDYNEST_LOCAL_AI_URL=http://127.0.0.1:8765
# Gemma 4 E4B HF snapshot dir (must contain config.json). Desktop bundles app-data/models/gemma-4-e4b-it when present.
STUDYNEST_GEMMA4_MODEL_PATH=./app-data/models/gemma-4-e4b-it

# StudyNest cloud API
STUDYNEST_API_URL=http://127.0.0.1:8000
