{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "app",
    "src",
    "App.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
