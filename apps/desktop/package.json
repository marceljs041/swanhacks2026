{
  "name": "@notegoat/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Note Goat — offline-first study workspace (desktop).",
  "author": "Note Goat",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/prepare-electron-bundle.mjs",
    "build": "tsc -b && vite build && electron-builder",
    "build:win": "pnpm run prebuild && tsc -b && vite build && electron-builder --win",
    "build:bundle": "pnpm run fetch-model && pnpm run build",
    "electron": "electron .",
    "typecheck": "tsc -b --noEmit",
    "seed": "tsx scripts/seed.ts",
    "fetch-model": "tsx scripts/fetch-model.ts"
  },
  "dependencies": {
    "@studynest/db-schema": "workspace:*",
    "@studynest/i18n": "workspace:*",
    "@studynest/prompts": "workspace:*",
    "@studynest/shared": "workspace:*",
    "@studynest/sync": "workspace:*",
    "@studynest/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.notegoat.desktop",
    "productName": "Note Goat",
    "artifactName": "${productName}-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../api",
        "to": "api",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/.mypy_cache/**",
          "!**/node_modules/**",
          "!**/*.egg-info/**"
        ]
      },
      {
        "from": "../../app-data/models",
        "to": "app-data/models",
        "filter": ["**/*.gguf"]
      }
    ],
    "mac": {
      "icon": "build/desktopicon.icns",
      "category": "public.app-category.education"
    },
    "win": {
      "icon": "build/desktopicon.ico",
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "linux": {
      "executableName": "note-goat",
      "category": "Education"
    },
    "nsis": {
      "differentialPackage": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.3.3",
    "electron-builder": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
